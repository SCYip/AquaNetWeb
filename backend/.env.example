# Server Configuration
PORT=3000
NODE_ENV=development

# Database (MySQL on Alibaba Cloud or local)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=aquanet

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# WeChat OAuth (optional - for Chinese users)
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_secret

# Alibaba Cloud SMS (optional - for phone verification in China)
ALIYUN_ACCESS_KEY_ID=your_access_key
ALIYUN_ACCESS_KEY_SECRET=your_secret
ALIYUN_SMS_SIGN_NAME=AquaNet
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxx

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
