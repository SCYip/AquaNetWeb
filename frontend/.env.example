# API Backend URL
# For Netlify deployment: set this to your Aliyun ECS public IP or domain
# Examples:
#   - http://8.135.45.252:3000/api        (IP address)
#   - https://api.yourdomain.com/api      (with domain + SSL)
#
# Dev: http://localhost:3000/api
# Production: set VITE_API_URL to your backend URL
VITE_API_URL=http://localhost:3000/api
